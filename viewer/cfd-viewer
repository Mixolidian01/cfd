#!/usr/bin/env bash
# =============================================================================
# cfd-viewer  —  launch / stop the CFD live viewer
#
# Usage:
#   ./cfd-viewer start [--vtk-dir PATH] [--port N] [--http-port N] [--solver CMD]
#   ./cfd-viewer stop
#   ./cfd-viewer restart [same options]
#   ./cfd-viewer status
#   ./cfd-viewer open        # reopen browser tab
#   ./cfd-viewer logs        # tail bridge log
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"

BRIDGE_SCRIPT="$SCRIPT_DIR/bridge.py"
HTML_FILE="$SCRIPT_DIR/viewer.html"
PID_FILE="/tmp/cfd_viewer_bridge.pid"
HTTP_PID_FILE="/tmp/cfd_viewer_http.pid"
LOG_FILE="/tmp/cfd_viewer_bridge.log"

DEFAULT_VTK_DIR="$PROJECT_DIR/build/output"
DEFAULT_PORT=8765
DEFAULT_HTTP_PORT=9000

# ── colours ───────────────────────────────────────────────────────────────────
green()  { printf "\033[32m%s\033[0m\n" "$*"; }
red()    { printf "\033[31m%s\033[0m\n" "$*"; }
yellow() { printf "\033[33m%s\033[0m\n" "$*"; }
dim()    { printf "\033[2m%s\033[0m\n"  "$*"; }

# ── helpers ───────────────────────────────────────────────────────────────────
is_running() {
    local pid_file="$1"
    [[ -f "$pid_file" ]] && kill -0 "$(cat "$pid_file")" 2>/dev/null
}

open_browser() {
    local url="$1"
    sleep 0.6
    # Try each browser in order, fall through on failure.
    # firefox.exe listed explicitly for WSL2 environments.
    local browsers=(
        "xdg-open"
        "sensible-browser"
        "firefox.exe"
        "firefox"
        "chromium-browser"
        "google-chrome"
        "open"
    )
    for browser in "${browsers[@]}"; do
        if command -v "$browser" &>/dev/null; then
            if "$browser" "$url" &>/dev/null 2>&1; then
                return 0
            fi
            # Browser exists but failed — try the next one
        fi
    done
    echo ""
    yellow "  ➜  Could not auto-open browser."
    yellow "     Open manually: $url"
}

# ── stop ─────────────────────────────────────────────────────────────────────
do_stop() {
    local stopped=0

    if is_running "$PID_FILE"; then
        kill "$(cat "$PID_FILE")" 2>/dev/null && rm -f "$PID_FILE"
        green "  ✓ Bridge stopped"
        stopped=1
    else
        rm -f "$PID_FILE" 2>/dev/null || true
        yellow "  Bridge was not running"
    fi

    if is_running "$HTTP_PID_FILE"; then
        kill "$(cat "$HTTP_PID_FILE")" 2>/dev/null && rm -f "$HTTP_PID_FILE"
        green "  ✓ HTTP server stopped"
        stopped=1
    else
        rm -f "$HTTP_PID_FILE" 2>/dev/null || true
    fi

    [[ $stopped -eq 0 ]] && yellow "  Nothing was running."
}

# ── status ────────────────────────────────────────────────────────────────────
do_status() {
    echo ""
    if is_running "$PID_FILE"; then
        green "  ● Bridge   running  (PID $(cat "$PID_FILE"))  log: $LOG_FILE"
    else
        red   "  ○ Bridge   stopped"
    fi
    if is_running "$HTTP_PID_FILE"; then
        green "  ● HTTP     running  (PID $(cat "$HTTP_PID_FILE"))"
    else
        red   "  ○ HTTP     stopped"
    fi
    echo ""
}

# ── start ─────────────────────────────────────────────────────────────────────
do_start() {
    local vtk_dir="$DEFAULT_VTK_DIR"
    local port="$DEFAULT_PORT"
    local http_port="$DEFAULT_HTTP_PORT"
    local solver_cmd=""
    local log_file_arg=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --vtk-dir)   vtk_dir="$2";      shift 2 ;;
            --port)      port="$2";         shift 2 ;;
            --http-port) http_port="$2";    shift 2 ;;
            --solver)    solver_cmd="$2";   shift 2 ;;
            --log-file)  log_file_arg="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    mkdir -p "$vtk_dir"

    # Stop any existing instance first
    if is_running "$PID_FILE" || is_running "$HTTP_PID_FILE"; then
        yellow "  Stopping existing instance…"
        do_stop
        sleep 0.5
    fi

    echo ""
    echo "  Starting CFD Live Viewer"
    echo "  ────────────────────────────────"

    # ── Bridge ───────────────────────────────────────────────────────────────
    BRIDGE_ARGS=(--vtk-dir "$vtk_dir" --port "$port")
    [[ -n "$solver_cmd"   ]] && BRIDGE_ARGS+=(--solver   "$solver_cmd")
    [[ -n "$log_file_arg" ]] && BRIDGE_ARGS+=(--log-file "$log_file_arg")

    python3 "$BRIDGE_SCRIPT" "${BRIDGE_ARGS[@]}" >> "$LOG_FILE" 2>&1 &
    echo $! > "$PID_FILE"
    sleep 0.5

    if is_running "$PID_FILE"; then
        green "  ✓ Bridge    ws://localhost:$port   (PID $(cat "$PID_FILE"))"
    else
        red   "  ✗ Bridge failed — check log: $LOG_FILE"
        tail -20 "$LOG_FILE"
        exit 1
    fi

    # ── HTTP server — serves ONLY viewer.html, not a directory listing ────────
    # Use Python to serve a single file at / to avoid exposing the folder tree.
    python3 - "$HTML_FILE" "$http_port" << 'PYEOF' &
import sys, http.server, socketserver, os

html_path = sys.argv[1]
port      = int(sys.argv[2])

class SingleFileHandler(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        # Redirect bare / or /viewer.html to the same content
        if self.path in ('/', '/viewer.html', '/index.html'):
            with open(html_path, 'rb') as f:
                data = f.read()
            self.send_response(200)
            self.send_header('Content-Type', 'text/html; charset=utf-8')
            self.send_header('Content-Length', str(len(data)))
            self.end_headers()
            self.wfile.write(data)
        else:
            self.send_error(404, 'Not found')
    def log_message(self, *_):
        pass  # silence access log

with socketserver.TCPServer(('', port), SingleFileHandler) as httpd:
    httpd.allow_reuse_address = True
    httpd.serve_forever()
PYEOF

    echo $! > "$HTTP_PID_FILE"
    sleep 0.4

    local viewer_url="http://localhost:$http_port"

    if is_running "$HTTP_PID_FILE"; then
        green "  ✓ Viewer    $viewer_url  (PID $(cat "$HTTP_PID_FILE"))"
    else
        red   "  ✗ HTTP server failed to start"
    fi

    dim   "  Logs:       $LOG_FILE"
    echo ""

    open_browser "$viewer_url"
}

# ── dispatch ──────────────────────────────────────────────────────────────────
CMD="${1:-help}"
shift || true

case "$CMD" in
    start)   do_start "$@" ;;
    stop)    echo ""; do_stop;   echo "" ;;
    status)  do_status ;;
    restart) do_stop; sleep 0.3; do_start "$@" ;;
    open)
        port="${DEFAULT_HTTP_PORT}"
        open_browser "http://localhost:$port"
        ;;
    logs)
        echo "  Tailing $LOG_FILE  (Ctrl+C to stop)"
        tail -f "$LOG_FILE"
        ;;
    help|*)
        echo ""
        echo "  Usage:  cfd-viewer <command> [options]"
        echo ""
        echo "  Commands:"
        echo "    start   [--vtk-dir PATH] [--port N] [--http-port N]"
        echo "            [--solver CMD] [--log-file PATH]"
        echo "    stop"
        echo "    restart [same options as start]"
        echo "    status"
        echo "    open    (reopen browser tab)"
        echo "    logs    (tail bridge log live)"
        echo ""
        echo "  Examples:"
        echo "    ./cfd-viewer start"
        echo "    ./cfd-viewer start --vtk-dir ~/dev/cfd/build/output"
        echo "    ./cfd-viewer stop"
        echo "    ./cfd-viewer logs"
        echo ""
        ;;
esac
